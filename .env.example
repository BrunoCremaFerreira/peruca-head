# Peruca brain API (the "intelligence" lives in ../peruca, not here).
PERUCA_API_URL=http://localhost:8000

# Stable identity for this device/user. Peruca keeps per-user persistent memory,
# so keep this constant for a given head. Single-user for now.
EXTERNAL_USER_ID=peruca-head-device

# Conversation thread id. A fixed value keeps the whole session in one thread.
CHAT_ID=peruca-head-session

# Timeout (seconds) for calls to the brain API.
REQUEST_TIMEOUT_SECONDS=30

# --- Voice output (TTS, Phase 1) ---
# Disabled by default so the text chat runs without a Piper voice on disk.
TTS_ENABLED=false
# Path to the pt-BR Piper voice .onnx (its .onnx.json must sit beside it).
# Recommended default voice: pt_BR-faber-medium.
PIPER_VOICE_PATH=
# Speech rate: > 1.0 slows speech down, < 1.0 speeds it up.
PIPER_LENGTH_SCALE=1.0

# --- Voice input (STT + VAD, Phase 2) ---
# faster-whisper model (downloaded by name on first use). Start with "small".
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
STT_LANGUAGE=pt
WHISPER_BEAM_SIZE=5
# Capture + silero-vad (record until silence). Capture at 16 kHz mono int16.
CAPTURE_SAMPLE_RATE=16000
VAD_FRAME_SIZE=512
VAD_SPEECH_THRESHOLD=0.5
VAD_MIN_SILENCE_MS=800
VAD_MAX_RECORDING_MS=15000
VAD_PRE_ROLL_MS=300
VAD_MIN_SPEECH_MS=250

# --- Robustness & feedback (Phase 4) ---
LOG_LEVEL=INFO
# Start cue: a short beep meaning "you can speak", played before recording.
# Speak AFTER the beep (audio captured during the cue is not recorded).
AUDIO_CUES_ENABLED=true
START_CUE_FREQ_HZ=880.0
START_CUE_VOLUME=0.3
# /health probe on startup: warn and continue if the brain is down.
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_TIMEOUT_SECONDS=2.0
